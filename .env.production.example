# ╔══════════════════════════════════════════════════════╗
# ║         DevPrep AI — Production .env template       ║
# ╚══════════════════════════════════════════════════════╝

# ── DATABASE (Neon PostgreSQL) ─────────────────────────────────────
# neon.tech → Project → Connection string (Pooled)
DATABASE_URL="postgresql://USER:PASS@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# neon.tech → Project → Connection string (Direct)
DIRECT_URL="postgresql://USER:PASS@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# ── JWT ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_HERE_abc123def456"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_HEX_STRING_xyz789"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── EMAIL (Gmail SMTP) ─────────────────────────────────────────────
# Gmail → Settings → Security → App passwords → Create
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
FROM_EMAIL="DevPrep AI <noreply@devprep.ai>"

# ── ANTHROPIC AI ───────────────────────────────────────────────────
# console.anthropic.com → API Keys → Create
ANTHROPIC_API_KEY="sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ── SERVER ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="production"

# ── CLIENT ─────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
CLIENT_URL="https://devprep-ai.vercel.app"
