# ─── DATABASE (Neon PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/devprep?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/devprep?sslmode=require"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-very-long-random-string-at-least-64-chars-abc123"
JWT_REFRESH_SECRET="change-this-refresh-secret-also-very-long-random-string-xyz789"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── EMAIL (Gmail) ───────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="DevPrep AI <noreply@devprep.ai>"

# ─── ANTHROPIC AI ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ─── APP ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"
CLIENT_URL="http://localhost:5173"
